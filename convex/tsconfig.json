{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "./_generated",
    "noEmit": true
  },
  "include": ["./**/*.ts", "./_generated/**/*.ts"]
}
